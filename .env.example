# ============================================================
# Saheed Oladele — Portfolio
# Copy to `.env.local` for development; set the same vars in your
# hosting provider for production.
# ============================================================

# Canonical site URL — no trailing slash. Drives every absolute URL on the
# site: canonicals, Open Graph, Twitter cards, JSON-LD, sitemap, robots,
# llms.txt, RSS. If this is wrong, every shared link is wrong.
# Default fallback (set in lib/seo.ts): https://saheedoladele.com
NEXT_PUBLIC_SITE_URL=https://saheedoladele.com
